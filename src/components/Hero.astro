---
import { getRelativeLocaleUrl } from "astro:i18n";

const locale = Astro.currentLocale ?? "pt";
const isPt = locale === "pt";

const t = (pt: string, en: string) => (isPt ? pt : en);

const subtitle = t("Analista e Desenvolvedor de Softwares", "Software Analyst and Developer");
const bio = t(
  "Desenvolvedor de software com experiência na construção de aplicações completas, combinando habilidades em desenvolvimento front-end e full-stack, bancos de dados, infraestrutura em nuvem e design UX/UI. Focado na criação de soluções práticas e eficientes para aprimorar a experiência do usuário. Participei de diversos projetos, contribuindo para o desenvolvimento de soluções funcionais, valorizando o aprendizado contínuo.",
  "Software Developer with experience in building complete applications, combining skills in front-end and full-stack development, databases, cloud infrastructure, and UX/UI design. Focused on creating practical and efficient solutions to enhance user experience. I have participated in several projects, contributing to the development of functional solutions while valuing continuous learning."
);
const printCv = t("Imprimir Currículo", "Print CV");
const contactMe = t("Fale Comigo", "Let's Talk");
const viewProjects = t("Ver Projetos", "View Projects");
---

<section
  id="profile"
  class="relative min-h-screen flex items-center justify-center pt-24 pb-16 overflow-hidden bg-background text-foreground"
>
  {/* Background blobs for premium depth */}
  <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[300px] md:w-[500px] h-[300px] md:h-[500px] bg-foreground/5 rounded-full blur-[80px] md:blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-[300px] md:w-[500px] h-[300px] md:h-[500px] bg-foreground/5 rounded-full blur-[80px] md:blur-[120px] pointer-events-none"></div>

  {/* Grid Pattern */}
  <div class="absolute inset-0 bg-[linear-gradient(to_right,var(--border)_1px,transparent_1px),linear-gradient(to_bottom,var(--border)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-30 pointer-events-none"></div>

  <div class="max-w-4xl mx-auto px-4 md:px-8 relative z-10 text-center">
    {/* Profile Image with subtle animations */}
    <div class="relative inline-block mb-8 animate-fade-in-scale">
      <div class="relative w-36 h-36 md:w-44 md:h-44 rounded-full overflow-hidden border-4 border-border shadow-2xl">
        <img
          src="/assets/profile-italo.jpg"
          alt="Ítalo Dórea"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    {/* Name and Title */}
    <div class="animate-fade-in-up">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-foreground mb-3">
        Ítalo Dórea
      </h1>
      
      <h2 class="text-xl md:text-2xl font-bold mb-6 flex items-center justify-center gap-3">
        <span class="text-accent font-semibold tracking-wider uppercase text-sm md:text-base">
          {subtitle}
        </span>
        <button
          onclick="window.print()"
          title={printCv}
          class="p-1.5 rounded-lg bg-muted border border-border hover:border-accent text-muted-foreground hover:text-foreground transition-all duration-300 shadow-sm print:hidden cursor-pointer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><path d="M6 9V3a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v6"></path><rect x="6" y="14" width="12" height="8" rx="1"></rect></svg>
        </button>
      </h2>
    </div>

    {/* Social Icons */}
    <div class="flex justify-center items-center gap-4 mb-8 print:hidden animate-fade-in-up delay-200">
      <a
        href="https://github.com/ifdc2308"
        target="_blank"
        rel="noopener noreferrer"
        class="w-11 h-11 rounded-xl bg-muted border border-border flex items-center justify-center text-muted-foreground hover:text-foreground hover:border-accent hover:bg-background hover:-translate-y-1 transition-all duration-300 shadow-md"
        aria-label="GitHub Profile"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/italo-dorea/"
        target="_blank"
        rel="noopener noreferrer"
        class="w-11 h-11 rounded-xl bg-muted border border-border flex items-center justify-center text-muted-foreground hover:text-foreground hover:border-accent hover:bg-background hover:-translate-y-1 transition-all duration-300 shadow-md"
        aria-label="LinkedIn Profile"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
        </svg>
      </a>
      <a
        href="https://www.instagram.com/italo_dorea/"
        target="_blank"
        rel="noopener noreferrer"
        class="w-11 h-11 rounded-xl bg-muted border border-border flex items-center justify-center text-muted-foreground hover:text-foreground hover:border-accent hover:bg-background hover:-translate-y-1 transition-all duration-300 shadow-md"
        aria-label="Instagram Profile"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
      <a
        href="mailto:italoiddev@gmail.com"
        class="w-11 h-11 rounded-xl bg-muted border border-border flex items-center justify-center text-muted-foreground hover:text-foreground hover:border-accent hover:bg-background hover:-translate-y-1 transition-all duration-300 shadow-md"
        aria-label="Send Email"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
      </a>
    </div>

    {/* Bio Text */}
    <p class="text-base md:text-lg text-muted-foreground leading-relaxed mb-10 max-w-2xl mx-auto animate-fade-in-up delay-300">
      {bio}
    </p>

    {/* CTA Buttons */}
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 print:hidden animate-fade-in-up delay-400">
      <a
        href="https://api.whatsapp.com/send?phone=5571985018352&text=Ol%C3%A1%20%C3%ADtalo%2C%20preciso%20falar%20contigo%20sobre%20assuntos%20de%20desenvolvimento"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full sm:w-auto px-8 py-3.5 rounded-xl bg-accent hover:opacity-90 font-semibold text-accent-foreground transition-all duration-300 shadow-md flex items-center justify-center gap-2 group hover:-translate-y-0.5"
      >
        {contactMe}
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
      
      <a
        href="#projects"
        class="w-full sm:w-auto px-8 py-3.5 rounded-xl bg-muted hover:bg-background font-semibold text-muted-foreground hover:text-foreground border border-border hover:border-accent transition-all duration-300 flex items-center justify-center hover:-translate-y-0.5"
      >
        {viewProjects}
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInScale {
    from {
      opacity: 0;
      transform: scale(0.85);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .animate-fade-in-scale {
    animation: fadeInScale 0.8s ease-out forwards;
  }

  .delay-200 {
    animation-delay: 0.2s;
    opacity: 0;
    animation-fill-mode: forwards;
  }

  .delay-300 {
    animation-delay: 0.3s;
    opacity: 0;
    animation-fill-mode: forwards;
  }

  .delay-400 {
    animation-delay: 0.4s;
    opacity: 0;
    animation-fill-mode: forwards;
  }
</style>
