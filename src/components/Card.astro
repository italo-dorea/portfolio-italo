---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { slugifyStr } from "@/utils/slugify";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const locale = Astro.currentLocale ?? "pt";
const isPt = locale === "pt";
const title = isPt ? data.title_pt : data.title_en;
const description = isPt ? data.summary_pt : data.summary_en;
const props = data;
---

<li class="my-6">
  <a
    href={getPostUrl(id, filePath, Astro.currentLocale)}
    class:list={[
      "text-accent inline-block text-lg font-medium",
      "decoration-dashed underline-offset-4 hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading transition:name={slugifyStr(title.replaceAll(".", "-"))}>
      {title}
    </Heading>
  </a>
  <div class="flex items-center gap-x-3 flex-wrap my-1.5">
    <Datetime {...props} />
    {data.category && (
      <span class="text-xs font-medium px-2.5 py-0.5 rounded border border-foreground/10 bg-foreground/5 text-muted-foreground uppercase tracking-wider">
        {data.category}
      </span>
    )}
  </div>
  <p>{description}</p>
</li>
