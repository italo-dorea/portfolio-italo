---
import { useTranslations } from "@/i18n";
import initialEducation from "../data/education.json";

const locale = Astro.currentLocale ?? "pt";
const t = useTranslations(locale);
const isPt = locale === "pt";

interface EducationItem {
  id: string;
  type: "education" | "certification";
  title_pt: string;
  title_en: string;
  institution: string;
  year: string;
  url?: string;
  skills: string[];
  order: number;
}

// Sort by order ascending
const items = [...initialEducation].sort((a, b) => a.order - b.order) as EducationItem[];

const academic = items.filter(item => item.type === "education");
const certifications = items.filter(item => item.type === "certification");
---

<section id="education" class="py-20 bg-background text-foreground relative overflow-hidden border-t border-border">
  <div class="max-w-6xl mx-auto px-4 md:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-foreground mb-4">
        {t.home.educationTitle}
      </h2>
      <div class="h-0.5 w-16 bg-accent mx-auto"></div>
      <p class="text-muted-foreground mt-4 max-w-lg mx-auto">
        {t.home.educationSubtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Academic Education Column -->
      <div>
        <h3 class="text-2xl font-bold text-foreground mb-8 pb-3 border-b border-border flex items-center gap-2.5">
          <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
          </svg>
          {t.home.academicTitle}
        </h3>

        {academic.length === 0 ? (
          <p class="text-muted-foreground italic text-sm">{isPt ? "Nenhuma formação cadastrada." : "No academic background registered."}</p>
        ) : (
          <div class="relative border-l border-border/60 pl-6 ml-3 space-y-12 py-2">
            {academic.map((item) => (
              <div class="relative group">
                <!-- Timeline dot indicator -->
                <div class="absolute -left-[31px] top-1.5 w-4 h-4 rounded-full border-2 border-border bg-background group-hover:border-accent transition-colors duration-300 flex items-center justify-center">
                  <div class="w-1.5 h-1.5 rounded-full bg-accent scale-0 group-hover:scale-100 transition-transform duration-305" />
                </div>

                <span class="inline-block text-xxs font-semibold uppercase text-muted-foreground tracking-wider mb-2 px-2 py-0.5 rounded border border-border bg-muted/40">
                  {item.year}
                </span>

                <h4 class="text-lg font-bold text-foreground leading-tight flex items-center gap-1.5">
                  {isPt ? item.title_pt : item.title_en}
                  {item.url && (
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-muted-foreground hover:text-accent transition-colors"
                      title={t.home.viewCredential}
                    >
                      <svg class="w-4 h-4 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </a>
                  )}
                </h4>
                
                <p class="text-muted-foreground text-sm font-medium mt-1">{item.institution}</p>

                {item.skills && item.skills.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-4">
                    {item.skills.map((skill) => (
                      <span class="text-xxs px-2 py-0.5 border border-foreground/10 bg-foreground/5 text-muted-foreground rounded transition-colors duration-300 hover:border-accent/30 hover:text-foreground">
                        {skill}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Courses & Certifications Column -->
      <div>
        <h3 class="text-2xl font-bold text-foreground mb-8 pb-3 border-b border-border flex items-center gap-2.5">
          <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
          {t.home.certificationsTitle}
        </h3>

        {certifications.length === 0 ? (
          <p class="text-muted-foreground italic text-sm">{isPt ? "Nenhum curso ou certificado cadastrado." : "No courses or certifications registered."}</p>
        ) : (
          <div class="relative border-l border-border/60 pl-6 ml-3 space-y-12 py-2">
            {certifications.map((item) => (
              <div class="relative group">
                <!-- Timeline dot indicator -->
                <div class="absolute -left-[31px] top-1.5 w-4 h-4 rounded-full border-2 border-border bg-background group-hover:border-accent transition-colors duration-300 flex items-center justify-center">
                  <div class="w-1.5 h-1.5 rounded-full bg-accent scale-0 group-hover:scale-100 transition-transform duration-305" />
                </div>

                <span class="inline-block text-xxs font-semibold uppercase text-muted-foreground tracking-wider mb-2 px-2 py-0.5 rounded border border-border bg-muted/40">
                  {item.year}
                </span>

                <h4 class="text-lg font-bold text-foreground leading-tight flex items-center gap-1.5">
                  {isPt ? item.title_pt : item.title_en}
                  {item.url && (
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-muted-foreground hover:text-accent transition-colors"
                      title={t.home.viewCredential}
                    >
                      <svg class="w-4 h-4 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </a>
                  )}
                </h4>
                
                <p class="text-muted-foreground text-sm font-medium mt-1">{item.institution}</p>

                {item.skills && item.skills.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-4">
                    {item.skills.map((skill) => (
                      <span class="text-xxs px-2 py-0.5 border border-foreground/10 bg-foreground/5 text-muted-foreground rounded transition-colors duration-300 hover:border-accent/30 hover:text-foreground">
                        {skill}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</section>
